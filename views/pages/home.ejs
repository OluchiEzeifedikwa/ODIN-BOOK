  <main class="main-content">
    <div class="feed">
      <% profiles.forEach(profile => { %>
        <div class="profile-card">
          <div class="profile-header">
            <div style="display: flex; align-items: center;">
              <img src="<%= profile.image || '' %>" alt="Profile Picture"
                onerror="this.style.display='none'">
              <span class="profile-username"><%= profile.user.username %></span>
            </div>
            <% if (profile.user.id !== user.id) { %>
              <button class="follow-btn" data-user-id="<%= profile.user.id %>" data-following="<%= profile.isFollowing ? 'true' : 'false' %>">
                <%= profile.isFollowing ? 'Unfollow' : 'Follow' %>
              </button>
            <% } %>
          </div>

          <div class="posts">
            <% profile.user.posts.forEach(post => { %>
              <div class="post-card">
                <% if(post.image){ %>
                  <img src="<%= post.image %>" alt="Post Image">
                <% } %>
                <p><%= post.content %></p>

                <% if (post.userId === user.id) { %>
                  <form action="/posts/delete/<%= post.id %>" method="POST" style="margin-top:8px" onsubmit="return confirm('Delete this post?')">
                    <button type="submit" class="delete-post-btn">
                      <i class="fa-solid fa-trash"></i> Delete
                    </button>
                  </form>
                <% } %>

                <div class="post-actions">
                  <button class="like-btn <%= post.isLiked ? 'liked' : '' %>" data-post-id="<%= post.id %>">
                    <i class="<%= post.isLiked ? 'fa-solid' : 'fa-regular' %> fa-heart"></i> <span><%= post._count.likes %></span>
                  </button>
                  <button class="comment-btn" data-post-id="<%= post.id %>">
                    💬 <span><%= post._count.comments %></span>
                  </button>
                </div>

                <!-- Comments (loaded lazily) -->
                <div class="comments" id="comments-<%= post.id %>" style="display:none;">
                  <p class="comments-loading" style="color:#aaa; margin-left:35px;">Loading...</p>
                </div>

                <!-- Comment form -->
                <form class="comment-form" id="form-<%= post.id %>" data-post-id="<%= post.id %>" action="/posts/<%= post.id %>/comments" method="POST" style="display:none;">
                  <textarea name="content" placeholder="Write a comment..." required></textarea>
                  <button type="submit">Post</button>
                  <button type="button" class="cancel-btn">Cancel</button>
                </form>
              </div>
            <% }) %>
          </div>
        </div>
      <% }) %>
    </div>
  </main>

  <script>
    const loadedComments = new Set();

    async function fetchComments(postId) {
      if (loadedComments.has(postId)) return;
      loadedComments.add(postId);

      const container = document.getElementById(`comments-${postId}`);
      try {
        const res = await fetch(`/posts/${postId}/comments`);
        const comments = await res.json();
        if (comments.length === 0) {
          container.innerHTML = '<p style="margin-left:35px;color:#aaa;">No comments yet.</p>';
        } else {
          container.innerHTML = comments.map(c => `
            <div class="comment">
              ${c.user.profile?.image ? `<img src="${c.user.profile.image}" alt="Avatar" onerror="this.style.display='none'">` : ''}
              <div class="comment-body">
                <div class="comment-meta">
                  <strong>${c.user.username}</strong>
                </div>
                <p>${c.content}</p>
              </div>
            </div>
          `).join('');
        }
      } catch (err) {
        container.innerHTML = '<p style="color:red;margin-left:35px;">Failed to load comments.</p>';
      }
    }

    // Toggle comments and comment form
    document.addEventListener('click', e => {
      const commentBtn = e.target.closest('.comment-btn');
      const cancelBtn = e.target.closest('.cancel-btn');

      if (commentBtn) {
        const postId = commentBtn.dataset.postId;
        const comments = document.getElementById(`comments-${postId}`);
        const form = document.getElementById(`form-${postId}`);
        const isVisible = comments.style.display === 'block';
        if (!isVisible) fetchComments(postId);
        comments.style.display = isVisible ? 'none' : 'block';
        form.style.display = isVisible ? 'none' : 'block';
      }

      if (cancelBtn) {
        const form = cancelBtn.closest('.comment-form');
        const postId = form.dataset.postId;
        document.getElementById(`comments-${postId}`).style.display = 'none';
        form.style.display = 'none';
      }
    });

    // Like button — optimistic update
    document.addEventListener('click', async e => {
      const btn = e.target.closest('.like-btn');
      if (!btn) return;

      const postId = btn.dataset.postId;
      const isLiked = btn.classList.contains('liked');
      const countEl = btn.querySelector('span');
      const icon = btn.querySelector('i');

      // Update UI immediately
      btn.classList.toggle('liked');
      icon.classList.toggle('fa-solid');
      icon.classList.toggle('fa-regular');
      countEl.textContent = isLiked ? parseInt(countEl.textContent) - 1 : parseInt(countEl.textContent) + 1;

      try {
        const res = await fetch(`/posts/${postId}/${isLiked ? 'unlike' : 'like'}`, {
          method: isLiked ? 'DELETE' : 'POST',
          headers: { 'Content-Type': 'application/json' },
        });
        if (!res.ok) throw new Error('Request failed');
        const data = await res.json();
        countEl.textContent = data.likes;
      } catch (err) {
        // Revert UI if request failed
        btn.classList.toggle('liked');
        icon.classList.toggle('fa-solid');
        icon.classList.toggle('fa-regular');
        countEl.textContent = isLiked ? parseInt(countEl.textContent) + 1 : parseInt(countEl.textContent) - 1;
      }
    });

    // Follow button
    document.addEventListener('click', e => {
      const btn = e.target.closest('.follow-btn');
      if (!btn) return;
      const id = btn.dataset.userId;
      const isFollowing = btn.dataset.following === 'true';
      fetch(isFollowing ? `/users/unfollow/${id}` : `/users/follow/${id}`, { method: 'POST' })
        .then(r => r.json())
        .then(data => {
          btn.textContent = data.following ? 'Unfollow' : 'Follow';
          btn.dataset.following = String(data.following);
        })
        .catch(err => console.error(err));
    });
  </script>
