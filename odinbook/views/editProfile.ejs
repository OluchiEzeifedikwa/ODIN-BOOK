<div class="post-container">
  <div class="board" id="profile">
    <h1 class="post-header">Edit Profile</h1>

    <p><strong>Username:</strong> <%= profile.user ? profile.user.username : 'Unknown user' %></p>

    <% if (profile) { %>
      <form enctype="multipart/form-data" action="/profiles/<%= profile.id %>" method="post">
        <input type="file" name="profileImage" accept="image/*">

        <% if (profile.image) { %>
          <img src="/uploads/<%= profile.image %>" alt="profile image" style="width:60px;height:60px;border-radius:50%;object-fit:cover;margin:10px 0;">
        <% } %>

        <p><strong>Bio:</strong><input type="text" name="bio" value="<%= profile.bio %>"></p>
        <p><strong>Location:</strong><input type="text" name="location" value="<%= profile.location || '' %>"></p>
        <p><strong>Pronoun:</strong><input type="text" name="pronoun" value="<%= profile.pronoun || '' %>"></p>

        <button type="submit">Save Changes</button>
      </form>
    <% } else { %>
      <p>User or profile not found.</p>
    <% } %>
  </div>
</div>
