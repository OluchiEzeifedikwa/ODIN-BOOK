<div class="post-page" style="max-width:680px;margin:0 auto;">

  <div class="post-card-single">

    <h1 class="post-header">Your Post</h1>

    <p class="post-text"><%= post.content %></p>

    <% if(post.image){ %>
      <img class="post-image" src="/uploads/<%= post.image %>" alt="post image">
    <% } %>

    <div class="post-icons">
      <a href="#"><i class="fa-regular fa-heart"></i></a>
      <a href="#"><i class="fa-regular fa-comment"></i></a>
      <a href="#"><i class="fa-regular fa-bookmark"></i></a>
      <a href="#"><i class="fa-regular fa-paper-plane"></i></a>
    </div>

    <form class="comment-form" style="display:flex;flex-direction:row;gap:8px;margin-top:16px;" action="/posts/<%= post.id %>/comments" method="post">
      <input type="hidden" name="postId" value="<%= post.id %>">
      <input type="text" name="content" placeholder="Write a comment..." class="comment-input">
      <button type="submit" class="comment-submit">Submit</button>
    </form>

  </div>

</div>
