<header class="navbar">

  <div class="nav-left">
    <button class="menu-toggle" aria-label="Toggle navigation">&#9776;</button>
    <!-- <h2>MeshBook</h2> -->
  </div>

  <div class="nav-center">
    <input type="text" placeholder="Search...">
  </div>

  <div class="nav-right">

    <% if (user) { %>
      <a href="/notifications" class="notif-bell" aria-label="Notifications">
        <i class="fa-solid fa-bell"></i>
        <% if (unreadCount > 0) { %>
          <span class="notif-badge"><%= unreadCount %></span>
        <% } %>
      </a>
      <a href="/profile">
        <% if (currentUserProfile && currentUserProfile.image) { %>
          <img src="/uploads/<%= currentUserProfile.image %>" class="profile-pic" onerror="this.src='/uploads/default.png'">
        <% } else { %>
          <div class="profile-pic-placeholder"><i class="fa-solid fa-user"></i></div>
        <% } %>
      </a>
    <% } else { %>
      <a href="/login">Login</a>
    <% } %>

  </div>

</header>