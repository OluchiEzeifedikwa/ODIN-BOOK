<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Odin Book</title>
    <link rel="stylesheet" href="styles.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.3/css/all.min.css">
    <style>

/* Comment button (emoji) */
.comment-btn {
  background: transparent;
  border: none;
  cursor: pointer;
  font-size: 1.4rem;
  display: inline-flex;
  align-items: center;
  margin-right: 10px;
  color: white;
}

/* Comment count next to emoji */
.comment-count {
  margin-left: 4px;
  font-size: 1.2rem;
  color: white;
}

/* Comment form */
.comment-form {
  margin-top: 0.5rem;
  padding: 10px;
  background-color: #2c2c2c;
  border-radius: 8px;
  display: none; /* hidden initially */
}

.comment-form textarea {
  width: 100%;
  min-height: 70px;
  padding: 6px;
  border-radius: 5px;
  border: none;
  resize: vertical;
  margin-bottom: 5px;
  background-color: #1f1f1f;
  color: white;
}

/* Comment form buttons */
.comment-form button {
  background-color: #3498db;
  color: white;
  border: none;
  padding: 5px 12px;
  border-radius: 5px;
  margin-right: 5px;
  cursor: pointer;
  font-size: 0.9rem;
}

.comment-form button:hover {
  background-color: #2980b9;
}

/* Like button styling */
.like-btn {
  background: none;
  border: none;
  font-size: 1.5rem;
  cursor: pointer;
  display: inline-flex;
  align-items: center;
  margin-right: 10px;
}

/* Heart icon */
.heart {
  color: white;
  font-size: 1.5rem;
  margin-left: 4px;
}

/* Keep red only when liked */
.like-btn.liked .heart {
  color: #e74c3c;
}

/* Default heart outline */
.heart::before {
  content: "♡";
}

/* Filled heart when liked */
.like-btn.liked .heart::before {
  content: "❤️";
  color: #e74c3c;
}

/* Align like/comment buttons horizontally */
.post-actions {
  display: flex;
  align-items: center;
  margin-top: 8px;
}


</style>
</head>

<body>
    <%- include('partials/navbar') %>
        
        <div class="container">
        <section class="board" id="following">
            <h1>Recent Notification</h1>
            <a href="/profiles">following</a>
            <form action="/search" method="get">
                <input style="background-color: #ccc;" name="q" value="<%= term %>" placeholder="Search for users">
                <button type="submit">Go</button>
            </form>

        </section>
        
        <!-- To create a post -->
        <section class="board" id="createpost">
            <form enctype="multipart/form-data" action="/posts" method="post">
                <label for="">What is the Update?</label>
                <input type="file" name="postImage" accept="image/*">
                <label for="content">Content</label>
                <input type="text" id="content" name="content" required>
                <button type="submit">Post</button>
            </form>
        </section>

        <section class="board" id="showpost">
            <a href="/posts">Show All posts</a>
            <a href="/profiles">Following</a>
        </section>
        
        <section class="board" id="pictures">
           <h1>Recent Notification</h1>
            <% if (notifications.length) { %>
                <% notifications.forEach(n => { %>
                  <li class="<%= n.read ? 'read' : 'unread' %>">
                    <!-- same markup as before, but using `n` directly -->
                  </li>
                <% }) %>
              <% } else { %>
                <li>No new notifications.</li>
              <% } %>


            
           <!-- To display all profiles -->
           <%- include('partials/profiles', { profiles, user }) %>


        <div class="search-container">
            <input type="search" id="search-input" placeholder="Search...">
            <button type="submit" id="search-button">
                <i class="fa fa-search"></i>
            </button> 
        </div>
    </div>

    
      

<script>
// To display the comment form    
document.addEventListener('DOMContentLoaded', () => {
  document.addEventListener('click', async e => {
    // 1️⃣ Show the comment form
    if (e.target.classList.contains('comment-btn')) {
      const postId = e.target.dataset.postId;
      const form = document.querySelector(`.comment-form[data-post-id="${postId}"]`);
      if (form) form.style.display = 'block';  
    }

    // 2️⃣ Hide the form
    if (e.target.classList.contains('cancel-btn')) {
      const form = e.target.closest('.comment-form');
      if (form) form.style.display = 'none';
    } 
  });
}); 


// To like a post
document.body.addEventListener('click', async e => {
  const btn = e.target.closest('.like-btn');
  if (!btn) return;

  const postId = btn.dataset.postId;
  const isLiked = btn.classList.contains('liked');

  try {
    const method = isLiked ? 'DELETE' : 'POST';
    const resp = await fetch(`/posts/${postId}/${isLiked ? 'unlike' : 'like'}`, {
      method,
      headers: { 'Content-Type': 'application/json' }
    });
    const data = await resp.json();

    btn.classList.toggle('liked');
    btn.querySelector('.heart').textContent = `${data.likes}`;
} catch (err) {
    console.error(err);
  }
});

// To follow a user
document.addEventListener('click', e => {
  const btn = e.target.closest('.follow-btn');
  if (!btn) return;

  const receiverId = btn.dataset.userId;
  const isFollowing = btn.dataset.following === 'true';

  // Choose endpoint and new text
  const url = isFollowing
    ? `/users/unfollow/${receiverId}`
    : `/users/follow/${receiverId}`;

  const newText = isFollowing ? 'Follow' : 'Unfollow';
  const newState = !isFollowing;

  fetch(url, { method: 'POST'})

  .then(r => r.json())
  .then(data => 
    {
    btn.textContent = data.following ? 'Unfollow' : 'Follow';
    btn.dataset.following = String(data.following);
  })
  .catch(err => console.error(err));
});



</script>
</body>
</html>