<div style="max-width: 600px; margin: 0 auto;">
  <h2 style="margin-bottom: 20px; color: #fff;">Follow Requests</h2>

  <% if (requests.length === 0) { %>
    <p style="color: #94a3b8;">No pending follow requests.</p>
  <% } else { %>
    <div style="display: flex; flex-direction: column; gap: 12px;">
      <% requests.forEach(request => { %>
        <div style="background: #1e293b; border-radius: 10px; padding: 14px; display: flex; align-items: center; justify-content: space-between; gap: 12px;">

          <span style="color: #e2e8f0; font-weight: 600;"><%= request.follower.username %></span>

          <div style="display: flex; gap: 8px;">
            <form action="/follow/requests/<%= request.id %>/accept" method="post">
              <button type="submit" style="padding: 6px 16px; border: none; border-radius: 6px; background: #3b82f6; color: #fff; font-weight: 600; cursor: pointer;">
                Accept
              </button>
            </form>

            <form action="/follow/requests/<%= request.id %>/reject" method="post">
              <button type="submit" style="padding: 6px 16px; border: none; border-radius: 6px; background: #334155; color: #94a3b8; font-weight: 600; cursor: pointer;">
                Reject
              </button>
            </form>
          </div>

        </div>
      <% }) %>
    </div>
  <% } %>
</div>
