<aside class="sidebar">
    <div class="sidebar-brand">MeshBook</div>
    <% if (user) { %>
      <div class="sidebar-welcome">Welcome, <span><%= user.username %></span></div>
    <% } %>
    <ul>
      <% links.forEach(link => { %>
        <li>
          <a href="<%= link.href %>" style="position:relative;">
            <% if(link.icon){ %>
              <i class="<%= link.icon %>"></i>
            <% } %>
            <%= link.text %>
            <% if (link.href === '/notifications' && unreadCount > 0) { %>
              <span class="notif-badge sidebar-notif-badge"><%= unreadCount %></span>
            <% } %>
          </a>
        </li>
      <% }) %>
    </ul>
  </aside>
