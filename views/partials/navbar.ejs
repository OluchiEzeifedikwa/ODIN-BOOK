<header class="navbar">

  <div class="nav-left">
    <button class="menu-toggle" aria-label="Toggle menu">
      <i class="fa-solid fa-bars"></i>
    </button>
  </div>

  <div class="nav-center">
    <form action="/search" method="GET" class="search-form">
      <input type="text" name="q" placeholder="Search users..." value="<%= typeof searchTerm !== 'undefined' ? searchTerm : '' %>">
      <button type="submit" class="search-btn"><i class="fa-solid fa-arrow-right"></i></button>
    </form>
  </div>

  <div class="nav-right">

    <% if (user) { %>
      <a href="/notifications" class="notif-bell" aria-label="Notifications">
        <i class="fa-solid fa-bell"></i>
        <% if (unreadCount > 0) { %>
          <span class="notif-badge"><%= unreadCount %></span>
        <% } %>
      </a>
      <a href="/profile">
        <% if (currentUserProfile && currentUserProfile.image) { %>
          <img src="<%= currentUserProfile.image %>" class="profile-pic" onerror="this.style.display='none'">
        <% } else { %>
          <div class="profile-pic-placeholder"><i class="fa-solid fa-user"></i></div>
        <% } %>
      </a>
      <form action="/logout" method="POST" style="margin:0">
        <button type="submit" class="logout-btn">Logout</button>
      </form>
    <% } else { %>
      <a href="/login">Login</a>
    <% } %>

  </div>

</header>
