<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title || "Odin Book" %></title>

  <!-- Open Graph / LinkedIn preview -->
  <meta property="og:type" content="website">
  <meta property="og:url" content="https://odin-book-1.onrender.com">
  <meta property="og:title" content="Odin Book – Connect with friends">
  <meta property="og:description" content="A social media app where you can share posts, follow friends, like, comment and more.">
  <meta property="og:image" content="https://odin-book-1.onrender.com/images/screenshots/home.png">
  <meta name="twitter:card" content="summary_large_image">

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
</head>

<body>

<div class="sidebar-overlay" id="sidebar-overlay"></div>

<div class="layout">

  <!-- Sidebar -->
  <%- include("../partials/sidebar") %>

  <div class="main-content">

    <!-- Navbar -->
    <%- include("../partials/navbar") %>

    <!-- Page Content -->
    <main class="content">
      <%- body %>
    </main>

  </div>

</div>


<script>
  const sidebar = document.querySelector('.sidebar');
  const overlay = document.getElementById('sidebar-overlay');
  const toggleBtns = document.querySelectorAll('.menu-toggle');

  function openSidebar() {
    sidebar.classList.add('active');
    overlay.classList.add('active');
    document.body.style.overflow = 'hidden';
  }

  function closeSidebar() {
    sidebar.classList.remove('active');
    overlay.classList.remove('active');
    document.body.style.overflow = '';
  }

  toggleBtns.forEach(btn => btn.addEventListener('click', () => {
    sidebar.classList.contains('active') ? closeSidebar() : openSidebar();
  }));

  overlay.addEventListener('click', closeSidebar);

  // Close sidebar when a nav link is clicked on mobile
  sidebar.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      if (window.innerWidth <= 768) closeSidebar();
    });
  });
</script>

</body>
</html>
